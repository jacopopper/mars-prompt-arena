<mujoco model="mars_wake_up">
  <include file="go2.xml"/>

  <visual>
    <headlight diffuse="0.8 0.5 0.3" ambient="0.4 0.2 0.1" specular="0 0 0"/>
    <rgba haze="0.4 0.2 0.1 1"/>
    <global azimuth="-130" elevation="-20"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.6 0.25 0.1" rgb2="0.15 0.05 0.0" width="512" height="3072"/>
    <texture type="2d" name="mars_ground" builtin="checker" rgb1="0.55 0.25 0.12" rgb2="0.45 0.18 0.08"
      markrgb="0.6 0.3 0.15" width="300" height="300"/>
    <material name="mars_ground" texture="mars_ground" texuniform="true" texrepeat="8 8" reflectance="0.05"/>
    <material name="base_mat" rgba="0.2 0.4 0.85 1"/>
    <material name="rock_mat" rgba="0.45 0.22 0.12 1"/>
  </asset>

  <worldbody>
    <light pos="0 0 4" dir="0.2 0.2 -1" directional="true" diffuse="0.9 0.6 0.4" specular="0.1 0.05 0.0"/>
    <geom name="floor" size="0 0 0.05" type="plane" material="mars_ground"/>

    <!-- base entrance (win target) -->
    <body name="base_target" pos="10 0 0">
      <geom name="base_wall" type="box" size="1.2 0.1 1.0" pos="0 0 1.0" material="base_mat"/>
      <geom name="base_wall2" type="box" size="0.1 1.2 1.0" pos="-1.2 0 1.0" material="base_mat"/>
      <geom name="base_wall3" type="box" size="0.1 1.2 1.0" pos="1.2 0 1.0" material="base_mat"/>
      <geom name="base_door" type="box" size="0.4 0.05 0.6" pos="0 -0.1 0.6" rgba="0.1 0.7 0.3 1"/>
    </body>

    <!-- rocks for visual depth -->
    <geom type="box" size="0.4 0.3 0.25" pos="3 2 0.25"   euler="0 0 15"  material="rock_mat"/>
    <geom type="box" size="0.3 0.5 0.35" pos="6 -1.5 0.35" euler="0 0 -20" material="rock_mat"/>
    <geom type="box" size="0.5 0.2 0.2" pos="2 -3 0.2"    euler="0 0 40"  material="rock_mat"/>
    <geom type="box" size="0.2 0.4 0.3" pos="8 2 0.3"     euler="0 0 5"   material="rock_mat"/>
  </worldbody>
</mujoco>

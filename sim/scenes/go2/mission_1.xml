<mujoco model="mars_wake_up">
  <include file="go2.xml"/>

  <visual>
    <headlight diffuse="0.9 0.55 0.3" ambient="0.4 0.18 0.06" specular="0 0 0"/>
    <rgba haze="0.42 0.2 0.08 1"/>
    <global azimuth="-130" elevation="-20"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.72 0.3 0.08" rgb2="0.06 0.02 0.0" width="512" height="3072"/>
    <texture type="2d" name="mars_ground" builtin="gradient" rgb1="0.52 0.22 0.1" rgb2="0.36 0.13 0.05"
      width="512" height="512"/>
    <material name="mars_ground" texture="mars_ground" texuniform="true" texrepeat="6 6" reflectance="0.03"/>
    <material name="base_mat" rgba="0.2 0.4 0.85 1"/>
    <material name="rock_mat" rgba="0.48 0.24 0.13 1"/>
    <material name="rock_dark" rgba="0.3 0.13 0.06 1"/>
    <hfield name="terrain" nrow="64" ncol="64" size="30 30 0.5 0.1"/>
  </asset>

  <worldbody>
    <light pos="8 -5 12" dir="-0.4 0.3 -1" directional="true" diffuse="1.0 0.65 0.35" specular="0.04 0.02 0.0"/>
    <light pos="-4 6 6" dir="0.3 -0.4 -1" directional="true" diffuse="0.3 0.16 0.08" specular="0 0 0"/>
    <geom name="floor" size="0 0 0.05" type="plane" material="mars_ground"/>
    <geom type="hfield" hfield="terrain" material="mars_ground" contype="0" conaffinity="0"/>

    <!-- base entrance (win target) -->
    <body name="base_target" pos="10 0 0">
      <geom name="base_wall" type="box" size="1.2 0.1 1.0" pos="0 0 1.0" material="base_mat"/>
      <geom name="base_wall2" type="box" size="0.1 1.2 1.0" pos="-1.2 0 1.0" material="base_mat"/>
      <geom name="base_wall3" type="box" size="0.1 1.2 1.0" pos="1.2 0 1.0" material="base_mat"/>
      <geom name="base_door" type="box" size="0.4 0.05 0.6" pos="0 -0.1 0.6" rgba="0.1 0.7 0.3 1"/>
    </body>

    <!-- cluster 1 -->
    <geom type="capsule" size="0.25 0.3" pos="3 2 0.3" euler="20 0 15" material="rock_mat"/>
    <geom type="sphere" size="0.18" pos="3.5 2.3 0.18" material="rock_dark" contype="0" conaffinity="0"/>
    <geom type="box" size="0.15 0.2 0.16" pos="2.8 1.7 0.16" euler="0 0 30" material="rock_mat" contype="0" conaffinity="0"/>

    <!-- cluster 2 -->
    <geom type="capsule" size="0.28 0.38" pos="6 -1.5 0.38" euler="10 20 -20" material="rock_mat"/>
    <geom type="sphere" size="0.22" pos="6.5 -1.2 0.22" material="rock_dark" contype="0" conaffinity="0"/>
    <geom type="box" size="0.12 0.18 0.14" pos="5.8 -1.8 0.14" euler="0 0 55" material="rock_dark" contype="0" conaffinity="0"/>

    <!-- cluster 3 -->
    <geom type="capsule" size="0.22 0.28" pos="2 -3 0.28" euler="15 0 40" material="rock_mat"/>
    <geom type="sphere" size="0.14" pos="2.4 -3.3 0.14" material="rock_dark" contype="0" conaffinity="0"/>
    <geom type="sphere" size="0.1" pos="1.7 -2.8 0.1" material="rock_mat" contype="0" conaffinity="0"/>

    <!-- cluster 4 near base -->
    <geom type="capsule" size="0.22 0.28" pos="8 2 0.28" euler="0 15 5" material="rock_mat"/>
    <geom type="sphere" size="0.14" pos="8.4 2.3 0.14" material="rock_dark" contype="0" conaffinity="0"/>

    <!-- distant scatter (visual only) -->
    <geom type="capsule" size="0.4 0.6" pos="-5 8 0.6" euler="5 20 45" material="rock_mat" contype="0" conaffinity="0"/>
    <geom type="sphere" size="0.3" pos="-4.5 7.5 0.3" material="rock_dark" contype="0" conaffinity="0"/>
    <geom type="box" size="0.6 0.4 0.5" pos="13 -5 0.5" euler="0 0 -30" material="rock_mat" contype="0" conaffinity="0"/>
    <geom type="capsule" size="0.35 0.5" pos="-6 -4 0.5" euler="15 0 70" material="rock_mat" contype="0" conaffinity="0"/>
    <geom type="sphere" size="0.45" pos="14 3 0.45" material="rock_dark" contype="0" conaffinity="0"/>
  </worldbody>
</mujoco>

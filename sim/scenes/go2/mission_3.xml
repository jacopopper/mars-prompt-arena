<mujoco model="mars_signal">
  <include file="go2.xml"/>

  <visual>
    <headlight diffuse="0.7 0.45 0.25" ambient="0.35 0.15 0.05" specular="0 0 0"/>
    <rgba haze="0.35 0.18 0.08 1"/>
    <global azimuth="-130" elevation="-20"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.55 0.22 0.08" rgb2="0.1 0.03 0.0" width="512" height="3072"/>
    <texture type="2d" name="mars_ground" builtin="checker" rgb1="0.55 0.25 0.12" rgb2="0.45 0.18 0.08"
      markrgb="0.6 0.3 0.15" width="300" height="300"/>
    <material name="mars_ground" texture="mars_ground" texuniform="true" texrepeat="8 8" reflectance="0.05"/>
    <material name="wreck_mat" rgba="0.5 0.15 0.1 1"/>
    <material name="rock_mat" rgba="0.45 0.22 0.12 1"/>
  </asset>

  <worldbody>
    <light pos="0 0 4" dir="0.2 0.2 -1" directional="true" diffuse="0.85 0.55 0.35" specular="0.05 0.02 0.0"/>
    <geom name="floor" size="0 0 0.05" type="plane" material="mars_ground"/>

    <!-- wreck 1 -->
    <body name="wreck_1" pos="5 3 0">
      <geom type="cylinder" size="0.35 0.25" pos="0 0 0.25" material="wreck_mat"/>
      <geom type="box" size="0.2 0.05 0.4" pos="0.1 0 0.6" euler="0 15 0" material="wreck_mat"/>
      <geom type="sphere" size="0.1" pos="0 0 0.7" rgba="1.0 0.3 0.1 1" contype="0" conaffinity="0"/>
    </body>

    <!-- wreck 2 -->
    <body name="wreck_2" pos="-3 7 0">
      <geom type="cylinder" size="0.35 0.25" pos="0 0 0.25" material="wreck_mat"/>
      <geom type="box" size="0.05 0.2 0.4" pos="0 0.1 0.6" euler="10 0 0" material="wreck_mat"/>
      <geom type="sphere" size="0.1" pos="0 0 0.7" rgba="1.0 0.3 0.1 1" contype="0" conaffinity="0"/>
    </body>

    <!-- wreck 3 -->
    <body name="wreck_3" pos="9 -4 0">
      <geom type="cylinder" size="0.35 0.25" pos="0 0 0.25" material="wreck_mat"/>
      <geom type="box" size="0.15 0.05 0.35" pos="-0.1 0 0.55" euler="0 -20 0" material="wreck_mat"/>
      <geom type="sphere" size="0.1" pos="0 0 0.7" rgba="1.0 0.3 0.1 1" contype="0" conaffinity="0"/>
    </body>

    <!-- rocks -->
    <geom type="box" size="0.5 0.3 0.4" pos="2 1 0.4"    euler="0 0 25"  material="rock_mat"/>
    <geom type="box" size="0.4 0.6 0.5" pos="-1 4 0.5"   euler="0 0 -15" material="rock_mat"/>
    <geom type="box" size="0.3 0.3 0.35" pos="7 0 0.35"  euler="0 0 45"  material="rock_mat"/>
    <geom type="box" size="0.6 0.2 0.3" pos="4 -2 0.3"   euler="0 0 10"  material="rock_mat"/>
    <geom type="box" size="0.3 0.5 0.4" pos="-2 5.5 0.4" euler="0 0 30"  material="rock_mat"/>
    <geom type="box" size="0.4 0.3 0.3" pos="6 -2 0.3"   euler="0 0 -40" material="rock_mat"/>
  </worldbody>
</mujoco>

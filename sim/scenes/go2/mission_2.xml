<mujoco model="mars_storm">
  <include file="go2.xml"/>

  <visual>
    <headlight diffuse="0.46 0.33 0.22" ambient="0.14 0.09 0.05" specular="0.02 0.01 0.01"/>
    <rgba haze="0.78 0.56 0.31 1"/>
    <global azimuth="-130" elevation="-18" offwidth="3072" offheight="1728"/>
  </visual>

  <asset>
    <!-- Storm sky: darker, more dust-obscured version of the panorama -->
    <texture type="skybox" builtin="gradient" rgb1="0.66 0.34 0.14" rgb2="0.09 0.03 0.01" width="512" height="3072"/>
    <texture type="2d" name="ground_tex" file="assets/mars_ground.png"/>
    <material name="mars_ground" texture="ground_tex" texuniform="true" texrepeat="20 20" reflectance="0.04" rgba="0.86 0.78 0.70 1"/>
    <material name="shelter_mat" rgba="0.71 0.64 0.52 1" specular="0.14" shininess="0.24"/>
    <material name="shelter_metal" rgba="0.44 0.41 0.37 1" specular="0.24" shininess="0.58"/>
    <material name="storm_panel" rgba="0.19 0.22 0.26 1" specular="0.16" shininess="0.48"/>
    <material name="rock_mat"    rgba="0.48 0.34 0.21 1"/>
    <material name="rock_dark"   rgba="0.29 0.22 0.16 1"/>
    <material name="rock_light"  rgba="0.62 0.46 0.29 1"/>
    <material name="mesa_mat"    rgba="0.24 0.15 0.10 1"/>
    <hfield name="terrain" nrow="64" ncol="64" size="30 30 0.5 0.1"/>
  </asset>

  <worldbody>
    <light pos="5 -8 10" dir="-0.3 0.5 -1" directional="true"
           diffuse="0.64 0.48 0.28" specular="0.04 0.02 0.01"/>
    <light pos="-6 4 5" dir="0.4 -0.3 -1" directional="true"
           diffuse="0.34 0.20 0.08" specular="0 0 0"/>
    <light pos="0 0 10" dir="-0.1 0.1 -1" directional="true"
           diffuse="0.12 0.08 0.03" specular="0 0 0"/>

    <geom name="floor" size="0 0 0.05" type="plane" material="mars_ground"/>
    <geom type="hfield" hfield="terrain" material="mars_ground" contype="0" conaffinity="0"/>

    <!-- storm horizon and dunes silhouette -->
    <geom type="box" size="16 2.2 2.2" pos="0 19 2.2" euler="0 5 0" material="mesa_mat" contype="0" conaffinity="0"/>
    <geom type="capsule" size="1.6 8.0" pos="-17 11 2.2" euler="0 14 84" material="mesa_mat" contype="0" conaffinity="0"/>
    <geom type="capsule" size="2.2 9.0" pos="18 -10 2.8" euler="0 18 98" material="mesa_mat" contype="0" conaffinity="0"/>

    <!-- Emergency shelter (win target) — rugged outpost style -->
    <body name="shelter_target" pos="8 5 0">
      <!-- Main box structure -->
      <geom type="box" size="1.4 1.2 1.0" pos="0 0 1.0" material="shelter_mat"/>
      <!-- Reinforced roof -->
      <geom type="box" size="1.5 1.3 0.12" pos="0 0 2.10" material="shelter_metal"/>
      <!-- Door -->
      <geom type="box" size="0.36 0.08 0.64" pos="0 -1.26 0.66" rgba="0.22 0.24 0.28 1"/>
      <!-- Warning light (amber, storm beacon) -->
      <geom type="sphere" size="0.14" pos="0 0 2.30"
            rgba="1.0 0.65 0.10 1" contype="0" conaffinity="0"/>
      <!-- Support struts -->
      <geom type="cylinder" size="0.06 1.0" pos="-1.3 -1.1 1.0"
            euler="0 0 0" material="shelter_metal" contype="0" conaffinity="0"/>
      <geom type="cylinder" size="0.06 1.0" pos=" 1.3 -1.1 1.0"
            euler="0 0 0" material="shelter_metal" contype="0" conaffinity="0"/>
      <geom type="box" size="0.92 0.03 0.56" pos="-2.05 0.10 1.34"
            euler="0 12 6" material="storm_panel"/>
      <geom type="box" size="0.92 0.03 0.56" pos=" 2.05 0.10 1.34"
            euler="0 -12 -6" material="storm_panel"/>
      <geom type="cylinder" size="0.05 1.25" pos="-1.25 0.10 1.18" material="shelter_metal"/>
      <geom type="cylinder" size="0.05 1.25" pos=" 1.25 0.10 1.18" material="shelter_metal"/>
      <geom type="cylinder" size="0.04 1.55" pos="-2.45 0.95 1.55" material="shelter_metal"/>
      <geom type="sphere" size="0.09" pos="-2.45 0.95 3.12" rgba="0.95 0.65 0.15 1" contype="0" conaffinity="0"/>
    </body>

    <!-- cluster 1 -->
    <geom type="capsule" size="0.38 0.48" pos="4 1 0.48"    euler="15 0 20"  material="rock_mat"/>
    <geom type="sphere"  size="0.24"      pos="4.5 1.4 0.24"                 material="rock_dark"  contype="0" conaffinity="0"/>
    <geom type="box"     size="0.18 0.28 0.22" pos="3.7 0.7 0.22" euler="0 0 -15" material="rock_dark" contype="0" conaffinity="0"/>

    <!-- cluster 2 -->
    <geom type="capsule" size="0.28 0.38" pos="2 4 0.38"    euler="0 20 -10" material="rock_mat"/>
    <geom type="sphere"  size="0.18"      pos="1.6 4.4 0.18"                 material="rock_dark"  contype="0" conaffinity="0"/>
    <geom type="box"     size="0.14 0.10 0.16" pos="2.3 3.8 0.16" euler="0 0 35" material="rock_light" contype="0" conaffinity="0"/>

    <!-- cluster 3 (big) -->
    <geom type="capsule" size="0.42 0.56" pos="6 2.5 0.56"  euler="20 0 35"  material="rock_mat"/>
    <geom type="sphere"  size="0.28"      pos="6.5 2.2 0.28"                 material="rock_dark"  contype="0" conaffinity="0"/>
    <geom type="box"     size="0.22 0.14 0.18" pos="5.8 2.8 0.18" euler="0 0 50" material="rock_mat" contype="0" conaffinity="0"/>

    <!-- cluster 4 -->
    <geom type="box"     size="0.38 0.38 0.28" pos="5 -1 0.28"   euler="0 0 50"  material="rock_light"/>
    <geom type="capsule" size="0.18 0.26"      pos="5.4 -0.7 0.26" euler="10 0 30" material="rock_dark" contype="0" conaffinity="0"/>

    <!-- cluster 5 -->
    <geom type="capsule" size="0.23 0.32" pos="1 3 0.32"    euler="0 15 -30" material="rock_mat"/>
    <geom type="sphere"  size="0.14"      pos="0.7 3.3 0.14"                 material="rock_dark"  contype="0" conaffinity="0"/>

    <!-- distant scatter -->
    <geom type="capsule" size="0.50 0.80" pos="-7 6 0.80"   euler="10 25 60" material="rock_mat"   contype="0" conaffinity="0"/>
    <geom type="sphere"  size="0.38"      pos="-6.5 5.5 0.38"                material="rock_dark"  contype="0" conaffinity="0"/>
    <geom type="box"     size="0.70 0.50 0.60" pos="14 2 0.60" euler="0 0 20" material="rock_light" contype="0" conaffinity="0"/>
    <geom type="capsule" size="0.40 0.60" pos="0 -7 0.60"   euler="20 0 80"  material="rock_mat"   contype="0" conaffinity="0"/>
    <geom type="sphere"  size="0.32"      pos="-1 -6.5 0.32"                 material="rock_dark"  contype="0" conaffinity="0"/>
    <geom type="box"     size="0.50 0.22 0.38" pos="6.8 -3.5 0.38" euler="0 0 18" material="shelter_metal"/>
    <geom type="capsule" size="0.10 0.65" pos="6.1 -3.0 0.65" euler="18 0 22" material="shelter_metal"/>
  </worldbody>
</mujoco>

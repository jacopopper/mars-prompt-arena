<mujoco model="mars_storm">
  <include file="go2.xml"/>

  <visual>
    <headlight diffuse="0.6 0.4 0.2" ambient="0.3 0.15 0.05" specular="0 0 0"/>
    <rgba haze="0.5 0.3 0.15 1"/>
    <global azimuth="-130" elevation="-20"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.5 0.2 0.05" rgb2="0.2 0.08 0.0" width="512" height="3072"/>
    <texture type="2d" name="mars_ground" builtin="checker" rgb1="0.55 0.25 0.12" rgb2="0.45 0.18 0.08"
      markrgb="0.6 0.3 0.15" width="300" height="300"/>
    <material name="mars_ground" texture="mars_ground" texuniform="true" texrepeat="8 8" reflectance="0.05"/>
    <material name="shelter_mat" rgba="0.7 0.6 0.2 1"/>
    <material name="rock_mat" rgba="0.45 0.22 0.12 1"/>
  </asset>

  <worldbody>
    <light pos="0 0 4" dir="0.2 0.2 -1" directional="true" diffuse="0.7 0.45 0.25" specular="0.0 0.0 0.0"/>
    <geom name="floor" size="0 0 0.05" type="plane" material="mars_ground"/>

    <!-- shelter (win target) -->
    <body name="shelter_target" pos="8 5 0">
      <geom name="shelter_body" type="box" size="1.5 1.5 1.2" pos="0 0 1.2" material="shelter_mat"/>
      <geom name="shelter_door" type="box" size="0.4 0.05 0.7" pos="0 -1.55 0.7" rgba="0.1 0.6 0.9 1"/>
      <geom name="shelter_light" type="sphere" size="0.15" pos="0 -1.5 1.8" rgba="0.2 1.0 0.4 1" contype="0" conaffinity="0"/>
    </body>

    <!-- rocks -->
    <geom type="box" size="0.5 0.3 0.4" pos="4 1 0.4"   euler="0 0 20"  material="rock_mat"/>
    <geom type="box" size="0.3 0.5 0.3" pos="2 4 0.3"   euler="0 0 -10" material="rock_mat"/>
    <geom type="box" size="0.6 0.3 0.5" pos="6 2.5 0.5" euler="0 0 35"  material="rock_mat"/>
    <geom type="box" size="0.4 0.4 0.3" pos="5 -1 0.3"  euler="0 0 50"  material="rock_mat"/>
    <geom type="box" size="0.3 0.2 0.4" pos="1 3 0.4"   euler="0 0 -30" material="rock_mat"/>
  </worldbody>
</mujoco>
